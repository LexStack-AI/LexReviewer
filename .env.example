# Display name of the chatbot used in prompts and branding. Default: LexReviewer
CHATBOT_NAME=LexReviewer

# Base URL of the backend service that provides linked documents API. No default; if unset, linked-documents tool returns an error.
LINKED_DOCUMENT_FETCH_URL=

# Maximum number of candidate chunks returned by the retriever (vector + BM25). Default: 10
MAX_NUMBER_OF_CANDIDATES_FOR_RETRIEVER=

# Unstructured.io API key; required for PDF chunking. No default.
UNSTRUCTURED_API_KEY=
# Max characters per chunk. Default: 6000
UNSTRUCTURED_MAX_CHARACTERS=
# Combine elements under this many characters into one chunk. Default: 2250
UNSTRUCTURED_COMBINE_UNDER_N_CHARS=
# Start a new chunk after this many characters. Default: 4500
UNSTRUCTURED_NEW_AFTER_N_CHARS=
# Overlap in characters between consecutive chunks. Default: 150
UNSTRUCTURED_OVERLAP=
# Whether to apply overlap across all chunk boundaries. Default: true
UNSTRUCTURED_OVERLAP_ALL=
# Whether to allow sections to span multiple pages. Default: true
UNSTRUCTURED_MULTIPAGE_SELECTION=
# Whether to split PDF by page. Default: true
UNSTRUCTURED_SPLIT_PDF_PAGE=
# Whether to allow failed splits. Default: true
UNSTRUCTURED_SPLIT_PDF_ALLOW_FAILED=
# Concurrency level for PDF splitting. Default: 15
UNSTRUCTURED_SPLIT_PDF_CONCURRENCY_LEVEL=
# Partition strategy: AUTO, FAST, HI_RES, OCR_ONLY. Default: AUTO
UNSTRUCTURED_STRATEGY=
# Chunking strategy (e.g. by_title). Default: by_title
UNSTRUCTURED_CHUNKING_STRATEGY=
# Whether to compute and store bounding boxes for chunks. Default: true
CHUNK_BBOXES_ENABLED=

# OpenAI API key; required for LLM and embeddings. No default.
OPENAI_API_KEY=
# Model for chat history summarization. Default: gpt-4.1-mini
OPENAI_CHAT_SUMMARY_MODEL=
# Model for chunk summarization. Default: gpt-4.1-mini
OPENAI_CHUNK_SUMMARY_MODEL=
# Model for required-tools generator (structured output). Default: gpt-4.1-mini
REQUIRED_TOOLS_GENERATOR_MODEL=
# Model used when agent reasoning is enabled. Default: gpt-5.2
REASNONING_AGENT_MODEL=
# Whether the agent may use reasoning/chain-of-thought. Default: true
AGENT_REASONING_ALLOWED=
# Model used when agent reasoning is disabled. Default: gpt-4
AGENT_MODEL=
# Embedding model name for vector store. Default: text-embedding-3-large
OPENAI_EMBEDDING_MODEL_NAME=

# MongoDB connection URL. Default: mongodb://localhost:27017
MONGODB_URL=
# MongoDB database name. Default: lexstack
MONGODB_DATABASE=
# MongoDB collection for chat history. Default: chat_history
MONGODB_CHAT_HISTORY_COLLECTION_NAME=
# MongoDB collection for document chunk docstore. Default: doc_store
MONGODB_DOC_STORE_COLLECTION_NAME=

# Qdrant server URL. No default (required with QDRANT_API_KEY).
QDRANT_URL=
# Qdrant API key. No default (required with QDRANT_URL).
QDRANT_API_KEY=
# Qdrant client timeout in seconds. Default: 60
QDRANT_TIMEOUT=
# Qdrant collection name for vectors. Default: documents
QDRANT_COLLECTION_NAME=
# Vector dimension size (must match embedding model). Default: 3072
QDRANT_VECTOR_SIZE=

# Sentry DSN (Data Source Name) for error tracking and monitoring. No default; if unset, Sentry is not initialized.
SENTRY_DSN=

# Langfuse secret key for authentication. No default; required with LANGFUSE_PUBLIC_KEY and LANGFUSE_HOST.
LANGFUSE_SECRET_KEY= 
# Langfuse public key for authentication. No default; required with LANGFUSE_SECRET_KEY and LANGFUSE_HOST.
LANGFUSE_PUBLIC_KEY= 
# Langfuse host URL (e.g., https://cloud.langfuse.com or self-hosted instance). No default; required with LANGFUSE_SECRET_KEY and LANGFUSE_PUBLIC_KEY.
LANGFUSE_HOST=